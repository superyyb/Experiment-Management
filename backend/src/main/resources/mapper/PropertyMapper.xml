<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rndlab.backend.mapper.PropertyMapper">

    <resultMap id="PropertyMap" type="com.rndlab.backend.entity.Property">
        <id property="id" column="id"/>
        <result property="experimentId" column="experiment_id"/>
        <result property="propertyName" column="property_name"/>
        <result property="propertyValue" column="property_value"/>
        <result property="propertyUnit" column="property_unit"/>
        <result property="propertyType" column="property_type"/>
        <result property="notes" column="notes"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findByExperimentId" resultMap="PropertyMap">
        SELECT * FROM properties
        WHERE experiment_id = #{experimentId}
        ORDER BY property_name
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO properties (
            experiment_id, property_name, property_value, property_unit, property_type, notes
        ) VALUES (
            #{experimentId}, #{propertyName}, #{propertyValue}, #{propertyUnit}, #{propertyType}, #{notes}
        )
    </insert>

    <delete id="deleteByExperimentId">
        DELETE FROM properties WHERE experiment_id = #{experimentId}
    </delete>

</mapper>

