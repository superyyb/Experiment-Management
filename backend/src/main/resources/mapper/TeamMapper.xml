<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rndlab.backend.mapper.TeamMapper">

    <resultMap id="TeamMap" type="com.rndlab.backend.entity.Team">
        <id property="id" column="id"/>
        <result property="teamName" column="team_name"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="TeamMap">
        SELECT * FROM teams ORDER BY team_name
    </select>

    <select id="findById" resultMap="TeamMap">
        SELECT * FROM teams WHERE id = #{id}
    </select>

</mapper>

